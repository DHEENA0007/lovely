{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://api.lovelygifts.co.in/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "https://api.lovelygifts.co.in/uploads/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}